{
  "name": "insijam",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Insijam — a calming geometric puzzle journey",
  "author": "Jarallah Al-Jarallah",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "icon": "node scripts/make-icon.mjs",
    "app": "electron .",
    "dist:win": "npm run build && electron-builder --win"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@fontsource/josefin-sans": "^5.1.0",
    "@fontsource/tajawal": "^5.1.0"
  },
  "build": {
    "appId": "com.jarallah.insijam",
    "productName": "Insijam",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Insijam",
      "artifactName": "Insijam-Setup-${version}.${ext}"
    }
  }
}
